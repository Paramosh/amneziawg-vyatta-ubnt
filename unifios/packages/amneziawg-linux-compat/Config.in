config BR2_PACKAGE_AMNEZIAWG_LINUX_COMPAT
	bool "amneziawg linux-compat"
	depends on BR2_LINUX_KERNEL
	# kernel module requires 3.10+
	depends on BR2_TOOLCHAIN_HEADERS_AT_LEAST_3_10
	# kernel module in upstream linux since 5.6
	depends on !BR2_TOOLCHAIN_HEADERS_AT_LEAST_5_6
	help
	  Amnezia WireGuard is a modified version of WireGuard that adds
	  additional obfuscation features to bypass censorship and VPN blocking.
	  It is an extremely simple yet fast and modern VPN that utilizes
	  state-of-the-art cryptography. It aims to be faster, simpler, leaner,
	  and more useful than IPSec, while avoiding the massive headache.

	  Support for WireGuard is included in Linux 5.6+. This
	  package provides a backport of the AmneziaWG kernel support for older
	  kernels.

	  https://amnezia.org

comment "amneziawg-linux-compat needs a toolchain w/ headers >= 3.10"
	depends on BR2_LINUX_KERNEL
	depends on !BR2_TOOLCHAIN_HEADERS_AT_LEAST_3_10

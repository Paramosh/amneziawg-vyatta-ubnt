#!/bin/sh

case "$1" in
  install|upgrade)
    if [ "$(uname -r)" != "KERNEL_VER" ]; then
      echo "This package contains the amneziawg kernel modules for KERNEL_VER, you're trying to install it on $(uname -r). Aborting."
      exit 1
    fi
    ;;
esac

if [ "$1" = "install" ] || dpkg --compare-versions "$(dpkg-query --showformat='${Version}' --show amneziawg 2>/dev/null || echo 0)" lt "0.0.20171111-1"; then
  dpkg-divert --package amneziawg --rename \
              --divert /opt/vyatta/share/perl5/Vyatta/Interface.pm.vyatta \
              --add /opt/vyatta/share/perl5/Vyatta/Interface.pm
fi

if [ "$1" = "install" ] || dpkg --compare-versions "$(dpkg-query --showformat='${Version}' --show amneziawg 2>/dev/null || echo 0)" lt "0.0.20180731-1"; then
  dpkg-divert --package amneziawg --rename \
              --divert /opt/vyatta/share/vyatta-cfg/templates/firewall/options/mss-clamp/interface-type/node.def.vyatta \
              --add /opt/vyatta/share/vyatta-cfg/templates/firewall/options/mss-clamp/interface-type/node.def
fi

if [ "$1" = "install" ] || dpkg --compare-versions "$(dpkg-query --showformat='${Version}' --show amneziawg 2>/dev/null || echo 0)" lt "0.0.20191219-1"; then
  dpkg-divert --package amneziawg --rename \
              --divert /opt/vyatta/share/vyatta-cfg/templates/firewall/options/mss-clamp6/interface-type/node.def.vyatta \
              --add /opt/vyatta/share/vyatta-cfg/templates/firewall/options/mss-clamp6/interface-type/node.def
fi

# Handle vyatta-check-allowed-ips.pl to support both wg and awg interfaces
# Don't divert if wireguard-vyatta-ubnt already manages it
if [ "$1" = "install" ]; then
    if [ -f /opt/vyatta/sbin/vyatta-check-allowed-ips.pl ]; then
        # File exists - check if it's already diverted by wireguard-vyatta-ubnt
        if ! dpkg-divert --list | grep -q "vyatta-check-allowed-ips.pl"; then
            # Not diverted yet - add diversion and install our version
            dpkg-divert --package amneziawg --rename \
                        --divert /opt/vyatta/sbin/vyatta-check-allowed-ips.pl.orig \
                        --add /opt/vyatta/sbin/vyatta-check-allowed-ips.pl || true
        fi
    fi
fi
